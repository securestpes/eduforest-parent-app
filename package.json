{
  "name": "eduforest-parent",
  "license": "0BSD",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "dotenv -e ./env/.env.development -- npx expo start",
    "start:clear": "dotenv -e ./env/.env.development -- npx expo start --clear",
    "start:dev": "dotenv -e ./env/.env.development -- node -p \"process.env.API_URL\"",
    "start:prod": "dotenv -e ./env/.env.production -- npx expo start",
    "android": "dotenv -e ./env/.env.development -- npx expo run:android",
    "android:prod": "dotenv -e ./env/.env.development -- npx expo run:android --variant=release",
    "ios": "dotenv -e ./env/.env.development -- npx expo run:ios",
    "web": "dotenv -e ./env/.env.development -- npx expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-navigation/bottom-tabs": "^7.3.12",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/stack": "^7.1.8",
    "@reduxjs/toolkit": "^2.6.1",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.8",
    "expo-speech": "^55.0.13",
    "expo-status-bar": "~3.0.8",
    "jwt-decode": "^4.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/config-types": "^54.0.0",
    "@types/react": "~19.1.10",
    "dotenv": "^17.2.1",
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "private": true
}
